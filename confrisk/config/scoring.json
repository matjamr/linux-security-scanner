{
  "version": "1.0",
  "model": {
    "formula": "risk = severity × asset_criticality × exposure × confidence",
    "priority_formula": "priority = risk ÷ effort"
  },
  "severity": {
    "info": 1.0,
    "low": 3.0,
    "medium": 5.5,
    "high": 8.0,
    "critical": 10.0
  },
  "asset_criticality": {
    "dev": 0.5,
    "internal": 0.8,
    "production": 1.1,
    "crown_jewel": 1.3
  },
  "exposure": {
    "local": 0.7,
    "adjacent_network": 0.95,
    "internet_facing": 1.25,
    "public": 1.5
  },
  "risk_bands": {
    "critical": 9.0,
    "high": 6.0,
    "medium": 3.5,
    "low": 1.5,
    "info": 0.0
  },
  "effort_multipliers": {
    "trivial": 1.0,
    "easy": 1.5,
    "moderate": 2.5,
    "hard": 4.0,
    "architectural": 5.0
  },
  "confidence_adjustments": {
    "confirmed": 1.0,
    "high": 0.95,
    "medium": 0.8,
    "low": 0.5,
    "speculative": 0.3
  }
}
